{
  "name": "glitnir-launcher",
  "version": "1.0.0",
  "description": "Launcher oficial do servidor Glitnir - Valheim",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently -k --raw \"vite\" \"wait-on tcp:5173 && electron . --single-instance\"",
    "build": "vite build && tsc -p tsconfig.electron.json && electron-builder",
    "preview": "vite preview"
  },
  "build": {
    "appId": "com.glitnir.launcher",
    "productName": "Glitnir Launcher",
    "win": {
      "target": "nsis",
      "icon": "src/assets/icon.ico"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "directories": {
      "output": "release"
    }
  },
  "dependencies": {
    "adm-zip": "^0.5.10",
    "axios": "^1.6.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.5",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^8.2.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vite-plugin-electron": "^0.28.0",
    "vite-plugin-electron-renderer": "^0.14.5",
    "wait-on": "^7.2.0"
  }
}
